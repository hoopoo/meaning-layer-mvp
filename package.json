{
  "name": "meaning-layer-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev --turbopack --hostname 127.0.0.1",
    "dev:webpack": "next dev --hostname 127.0.0.1",
    "dev:clean": "npm run clean && npm run dev",
    "build": "prisma migrate deploy && next build --turbopack",
    "build:next-only": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "node scripts/postinstall-prisma.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "worlds:import": "tsx scripts/import-roblox-worlds.mts",
    "worlds:import:vrchat": "tsx scripts/import-vrchat-worlds.mts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "15.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
