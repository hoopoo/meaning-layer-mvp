# PostgreSQL (local: Docker/Postgres.app, hosted: Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# VRChat importer (npm run worlds:import:vrchat) — API requires authentication.
# For GitHub Actions, prefer username/password (+ 2FA secret). Browser auth cookies expire quickly.
# VRCHAT_USERNAME="your_vrchat_username"
# VRCHAT_PASSWORD="your_vrchat_password"
# VRCHAT_2FA_SECRET="aaaa bbbb cccc dddd eeee ffff gggg hhhh"  # manual TOTP key from 2FA setup
# VRCHAT_AUTH_COOKIE="authcookie_..."                           # optional fallback only
# VRCHAT_TWO_FACTOR_AUTH_COOKIE="..."                           # optional 2FA device remembrance cookie
