# PostgreSQL (local: Docker/Postgres.app, hosted: Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# VRChat importer (npm run worlds:import:vrchat) — API requires authentication.
# Prefer a reused auth cookie for CI; username/password works locally but creates new sessions.
# VRCHAT_AUTH_COOKIE="authcookie_..."
# VRCHAT_USERNAME="your_vrchat_username"
# VRCHAT_PASSWORD="your_vrchat_password"
